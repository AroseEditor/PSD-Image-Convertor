# Dependencies
node_modules/

# Build output
out/
dist/
dist-electron/
build/
*.tsbuildinfo

# Env / secrets — this app never stores real keys in the repo, but keep the
# door shut in case a local .env is ever added for scripting/testing.
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
logs/

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# Test/debug scratch scripts (never committed, ad-hoc verification only)
__verify.mjs
__verify2.mjs
__verify3.mjs
__probe.mjs
